# Money Maker - Environment Variables
# Copy this file to .env and fill in your values.

# --- Required ---
GOOGLE_API_KEY=your_google_places_api_key

# --- Optional (enhance results) ---
SERPAPI_KEY=your_serpapi_key
GOOGLE_SEARCH_API_KEY=your_google_custom_search_key
GOOGLE_SEARCH_CX=your_google_custom_search_engine_id

# --- Paths (defaults work, override if needed) ---
# MM_LEADS_DIR=~/Documents/money-maker/leads/
# MM_DEPLOY_REPO=~/Documents/mm-demos/
# MM_DEPLOY_URL=https://yourusername.github.io/mm-demos
# MM_CAL_URL=cal.com/your-booking
# MM_SENDER_EMAIL=you@yourdomain.com
